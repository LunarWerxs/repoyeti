# deps & build
node_modules/
dist/
*.tsbuildinfo

# local secrets / env (bun auto-loads .env at startup) — NEVER commit
.env
.env.*
!.env.example

# local runtime state (the daemon writes to ~/.repoyeti, but never commit any local db copies)
*.db
*.db-wal
*.db-shm
.repoyeti/

# editor / os
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.vscode/
.idea/

# logs & test/coverage output
*.log
coverage/
tmp/

# Playwright E2E artifacts (web/) — regenerated per run, never committed
web/test-results/
web/playwright-report/
web/.playwright/

# bundled binaries (fetched per-platform, not committed)
vendor/cloudflared/

# tray launcher: the .lnk stores absolute paths — regenerate it per machine with
# misc\Create-Shortcut.ps1 (the scripts + icon under misc/ are committed).
/RepoYeti.lnk
