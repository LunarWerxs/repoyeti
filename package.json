{
  "name": "gitmob",
  "version": "0.0.1",
  "description": "System-wide remote git manager — a background daemon with a mobile dashboard.",
  "type": "module",
  "license": "MIT",
  "author": "L0garithmic <2claude@lunarwerx.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LunarWerxs/gitmob.git"
  },
  "homepage": "https://github.com/LunarWerxs/gitmob#readme",
  "bugs": {
    "url": "https://github.com/LunarWerxs/gitmob/issues"
  },
  "keywords": [
    "git",
    "bun",
    "daemon",
    "remote",
    "vcs",
    "pwa",
    "self-hosted",
    "developer-tools"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "gitmob": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts start",
    "dev": "bun run scripts/dev.ts",
    "status": "bun run src/index.ts status",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check:codes": "bun run scripts/check-error-codes.ts",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "check": "bun run check:codes && bun run check:boundaries",
    "build": "bun run scripts/build.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^6.2.3",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
