{
  "name": "repoyeti",
  "version": "0.13.0",
  "description": "System-wide remote git manager — a background daemon with a mobile dashboard.",
  "type": "module",
  "license": "MIT",
  "author": "L0garithmic <2claude@lunarwerx.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LunarWerxs/RepoYeti.git"
  },
  "homepage": "https://github.com/LunarWerxs/RepoYeti#readme",
  "bugs": {
    "url": "https://github.com/LunarWerxs/RepoYeti/issues"
  },
  "keywords": [
    "git",
    "bun",
    "daemon",
    "remote",
    "vcs",
    "pwa",
    "self-hosted",
    "developer-tools"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "repoyeti": "./src/index.ts"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "start": "bun run src/index.ts start",
    "dev": "bun run scripts/dev.ts",
    "status": "bun run src/index.ts status",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests --timeout 20000",
    "test:coverage": "bun test tests --coverage",
    "check:coverage": "bun run scripts/check-coverage.ts",
    "check:codes": "bun run scripts/check-error-codes.ts",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "check:libtypes": "bun run scripts/check-lib-types.mjs",
    "check:bytes": "bun run scripts/check-source-bytes.ts",
    "check:kit": "node ../lunarwerx-ui/sync.mjs --check --app repoyeti",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "bun run check:codes && bun run check:boundaries && bun run check:libtypes && bun run check:bytes && bun run lint",
    "build": "bun run scripts/build.ts"
  },
  "dependencies": {
    "@cnct/connect": "^0.3.0",
    "@cnct/locker": "^0.1.1",
    "hono": "^4.6.14",
    "jose": "^6.2.3",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.27.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@lore-vcs/sdk": "^0.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "1.3.14",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "koffi"
  ]
}
