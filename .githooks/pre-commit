#!/bin/sh
# RepoYeti pre-commit gate: web i18n compliance + Biome lint + tsc typecheck (no full build).
# Enable once with:  git config core.hooksPath .githooks
# Bypass a single commit with:  git commit --no-verify
if [ -f web/scripts/i18n-check.mjs ] && [ -d web/node_modules ]; then
  echo "› i18n-check…"
  if ! (cd web && node scripts/i18n-check.mjs); then
    echo "✗ i18n-check failed — fix the above, or 'git commit --no-verify' to bypass." >&2
    exit 1
  fi
fi

# Lint + typecheck mirror CI's `bun run check` / `typecheck`, caught locally before the push.
# Both are skipped gracefully if bun isn't on PATH (e.g. a non-dev environment).
if command -v bun >/dev/null 2>&1; then
  echo "› lint…"
  if ! bun run lint; then
    echo "✗ biome lint failed — fix the above, or 'git commit --no-verify' to bypass." >&2
    exit 1
  fi
  echo "› typecheck…"
  if ! bun run typecheck; then
    echo "✗ tsc typecheck failed — fix the above, or 'git commit --no-verify' to bypass." >&2
    exit 1
  fi
fi

# Kit-sync guard: a kit-synced file edited in this app instead of the kit forks it from every
# other app. Only staged files are considered, and a copy that MATCHES the kit (a re-sync) passes.
if command -v node >/dev/null 2>&1; then
  echo "› kit-sync guard…"
  node .githooks/check-kit-sync-staged.mjs repoyeti || exit 1
fi
